---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import SectionLabel from "../../components/SectionLabel.astro";
import LeafRating from "../../components/LeafRating.astro";

type Advisor = { name: string; url?: string };
type ResearchEntry = {
  title: string;
  lab: string;
  advisors: Advisor[];
  period: string;
  take: string;
};
type InternshipEntry = {
  role: string;
  org: string;
  period: string;
  take: string;
  kind: "internship" | "teaching";
};

const research: ResearchEntry[] = [
  {
    title: "Token Uncertainty in LLM Reasoning",
    lab: "McGill · COMP 400 Honours Project",
    advisors: [
      {
        name: "Prof. Siva Reddy",
        url: "https://scholar.google.com/citations?hl=en&user=LZZAAtoAAAAJ",
      },
      {
        name: "Gaurav Kamath",
        url: "https://scholar.google.com/citations?user=loIgKB0AAAAJ&hl=en",
      },
    ],
    period: "May – Aug 2026",
    take: "My honours project in Prof. Reddy's group, advised day-to-day by Gaurav. I am looking at whether token-level entropy spikes in an LLM's reasoning trace are a more faithful diagnostic of uncertainty than the confidence score the model says out loud, using PROBCOPA as a stress-test dataset for probabilistic reasoning.",
  },
  {
    title: "NLP Bias & Representation",
    lab: "McGill Artificial Intelligence Society",
    advisors: [],
    period: "Feb – Sep 2025",
    take: "An exploratory stretch of reading and literature review on cultural bias in transformer language models, focused on parliamentary corpora like the Nunavut Hansard against the Canadian Hansard. A lot of this was reading papers and trying to understand what masked language modeling bias evaluation actually looks like in practice.",
  },
  {
    title: "Directed Reading Program · Persistent Homology",
    lab: "McGill Mathematics & Statistics",
    advisors: [{ name: "Julien Cheng" }],
    period: "Jan – May 2025",
    take: "A semester-long reading program where I studied persistent homology under Julien Cheng. This was the first time I had to sit with graduate-level math for its own sake instead of for a course, and it let me me explore what theoretical math research really is.",
  },
  {
    title: "Triadic Patterns for Explainable AI",
    lab: "University of Regina, Computer Science",
    advisors: [
      {
        name: "Prof. Yiyu Yao",
        url: "https://scholar.google.com/citations?user=_aL0fcQAAAAJ&hl=en",
      },
      {
        name: "Qiaoyi Li",
        url: "https://scholar.google.com/citations?hl=en&user=pxErcl8AAAAJ",
      },
    ],
    period: "May 2024 – Feb 2025",
    take: "My first real research experience, working with Prof. Yao and Qiaoyi on triadic pattern structures for XAI. It became a first-author paper at IJCRS 2025 (Springer).",
  },
];

const internships: InternshipEntry[] = [
  {
    role: "Backend Developer, T&O Program",
    org: "RBC",
    period: "Incoming · May – Aug 2026",
    take: "Starting this May in Montreal on RBC's Technology & Operations internship program, joining a backend team. I'll be primarily working on backend using Java Spring Boot.",
    kind: "internship",
  },
  {
    role: "Full Stack Developer Co-op",
    org: "InterPro Pipe and Steel",
    period: "May – Aug 2025",
    take: "Spent the summer in Regina writing internal WPF apps used by the shipping, training, and finance teams. It was my first time writing C# and shipping something that real coworkers would use every week.",
    kind: "internship",
  },
  {
    role: "Course Assistant, MATH 208",
    org: "McGill University",
    period: "Fall 2025",
    take: "Introduction to Statistical Computing.",
    kind: "teaching",
  },
  {
    role: "Course Assistant, MATH 203",
    org: "McGill University",
    period: "Winter 2025",
    take: "Principles of Statistics 1",
    kind: "teaching",
  },
];

const workRoles = internships.filter((e) => e.kind === "internship");
const teachingRoles = internships.filter((e) => e.kind === "teaching");

const courseCollection = (await getCollection("courses")).sort((a, b) =>
  a.data.code.localeCompare(b.data.code)
);
const categoryOrder = [
  "AI & Machine Learning",
  "Computer Fundamentals",
  "Mathematical Foundations",
] as const;
const byCategory = new Map<string, typeof courseCollection>();
for (const c of courseCollection) {
  const k = c.data.category;
  if (!byCategory.has(k)) byCategory.set(k, [] as typeof courseCollection);
  byCategory.get(k)!.push(c);
}
const courseGroups = categoryOrder
  .filter((k) => byCategory.has(k))
  .map((k) => [k, byCategory.get(k)!] as const);
---

<Layout
  title="Experiences"
  description="Research, internships, and coursework at McGill."
  wide
>
  <h1 class="page-h1">Experiences</h1>
  <p class="page-lede">
    Research I'm doing on the side, the internships and roles that filled the
    gaps in between, and the coursework at McGill underneath it all.
  </p>

  <div class="anchor-bar">
    <a href="#research">Research</a>
    <a href="#internships">Internships</a>
    <a href="#courses">Courses</a>
    <span class="anchor-spacer"></span>
    <span class="anchor-meta">B.Sc. Hons. Computer Science · Minor Statistics</span>
  </div>

  <section class="mt-12" id="research">
    <SectionLabel>Research</SectionLabel>
    {
      research.map((r, i) => (
        <div class:list={["exp-row", { first: i === 0 }]}>
          <div class="exp-row-head">
            <div class="exp-title">{r.title}</div>
            <div class="exp-period">{r.period}</div>
          </div>
          <div class="exp-meta">
            {r.lab}
            {r.advisors.length > 0 && (
              <>
                {" · with "}
                {r.advisors.map((a, j) => (
                  <>
                    {j > 0 && ", "}
                    {a.url ? (
                      <a href={a.url} target="_blank" rel="noopener">
                        {a.name}
                      </a>
                    ) : (
                      a.name
                    )}
                  </>
                ))}
              </>
            )}
          </div>
          <p class="exp-take">{r.take}</p>
        </div>
      ))
    }
  </section>

  <section class="mt-14" id="internships">
    <SectionLabel>Internships</SectionLabel>
    {
      workRoles.map((e, i) => (
        <div class:list={["exp-row compact", { first: i === 0 }]}>
          <div class="exp-row-head">
            <div class="exp-title">
              {e.role}
              <span class="exp-org"> · {e.org}</span>
            </div>
            <div class="exp-period">{e.period}</div>
          </div>
          <p class="exp-take">{e.take}</p>
        </div>
      ))
    }
    {workRoles.length === 0 && <p class="text-muted">Nothing to show yet.</p>}

    {
      teachingRoles.length > 0 && (
        <div class="teaching-group">
          <div class="teaching-label">Teaching</div>
          {teachingRoles.map((e) => (
            <div class="exp-row compact">
              <div class="exp-row-head">
                <div class="exp-title">
                  {e.role}
                  <span class="exp-org"> · {e.org}</span>
                </div>
                <div class="exp-period">{e.period}</div>
              </div>
              <p class="exp-take">{e.take}</p>
            </div>
          ))}
        </div>
      )
    }
  </section>

  <section class="mt-14" id="courses">
    <SectionLabel>Courses</SectionLabel>
    {
      courseGroups.length === 0 && (
        <p class="text-muted">Coursework entries coming soon.</p>
      )
    }
    <div class="terms">
      {
        courseGroups.map(([category, courses]) => (
          <div class="term-block">
            <div class="term-head">
              <span>{category}</span>
              <span>
                {courses.length} course{courses.length === 1 ? "" : "s"}
              </span>
            </div>
            {courses.map((c) => (
              <div class="course-row">
                <span class="course-code">{c.data.code}</span>
                <div>
                  <div class="course-title">
                    {c.data.title}
                    {c.data.level === "honours" && (
                      <span class="course-badge">Honours</span>
                    )}
                    {c.data.level === "graduate" && (
                      <span class="course-badge">Graduate</span>
                    )}
                  </div>
                  <p class="course-desc">{c.data.description}</p>
                  {(c.data.instructor || c.data.term) && (
                    <p class="course-meta">
                      {c.data.instructor && <span>{c.data.instructor}</span>}
                      {c.data.instructor && c.data.term && (
                        <span class="dot"> · </span>
                      )}
                      {c.data.term && <span>{c.data.term}</span>}
                    </p>
                  )}
                </div>
                {typeof c.data.rating === "number" && (
                  <LeafRating n={c.data.rating} />
                )}
              </div>
            ))}
          </div>
        ))
      }
    </div>
  </section>
</Layout>

<style>
  .page-h1 {
    font-family: var(--font-serif);
    font-size: 44px;
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.05;
    margin: 0;
    color: var(--text);
  }
  .page-lede {
    font-family: var(--font-serif);
    font-size: 17px;
    color: var(--muted);
    margin: 12px 0 0;
    max-width: 58ch;
  }
  .anchor-bar {
    margin-top: 24px;
    display: flex;
    gap: 18px;
    font-family: var(--font-sans);
    font-size: 12px;
    color: var(--muted);
    border-bottom: 1px solid var(--border);
    padding-bottom: 10px;
    flex-wrap: wrap;
    align-items: center;
  }
  .anchor-bar a {
    color: var(--muted);
    text-decoration: none;
  }
  .anchor-bar a:hover {
    color: var(--accent);
  }
  .anchor-spacer {
    flex: 1;
  }
  .anchor-meta {
    color: var(--muted);
  }

  .mt-12 {
    margin-top: 3rem;
  }
  .mt-14 {
    margin-top: 3.5rem;
  }

  .exp-row {
    padding: 20px 0 22px;
    border-top: 1px solid var(--border);
  }
  .exp-row.first {
    border-top: 0;
  }
  .exp-row.compact {
    padding: 18px 0 20px;
  }
  .exp-row-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 16px;
    flex-wrap: wrap;
  }
  .exp-title {
    font-family: var(--font-serif);
    font-size: 20px;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--text);
  }
  .exp-row.compact .exp-title {
    font-size: 19px;
  }
  .exp-org {
    color: var(--muted);
    font-weight: 400;
  }
  .exp-period {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 11px;
    color: var(--muted);
    white-space: nowrap;
  }
  .exp-meta {
    font-family: var(--font-sans);
    font-size: 12.5px;
    color: var(--muted);
    margin-top: 4px;
  }
  .exp-take {
    font-family: var(--font-serif);
    font-size: 15px;
    color: var(--text);
    margin: 10px 0 0;
    line-height: 1.55;
  }
  .exp-meta a {
    color: var(--muted);
    text-decoration: underline;
    text-decoration-color: var(--border);
    text-underline-offset: 2px;
  }
  .exp-meta a:hover {
    color: var(--accent);
    text-decoration-color: var(--accent);
  }
  .teaching-group {
    margin-top: 28px;
  }
  .teaching-label {
    font-family: var(--font-sans);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    border-bottom: 1px solid var(--border);
    padding-bottom: 8px;
    margin-bottom: 4px;
  }

  .terms {
    display: flex;
    flex-direction: column;
    gap: 30px;
  }
  .term-head {
    font-family: var(--font-sans);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    border-bottom: 1px solid var(--border);
    padding-bottom: 8px;
    margin-bottom: 10px;
    display: flex;
    justify-content: space-between;
  }
  .course-row {
    display: grid;
    grid-template-columns: 78px 1fr auto;
    gap: 16px;
    padding: 12px 0;
    align-items: start;
    border-top: 1px solid var(--border);
  }
  .course-row:first-of-type {
    border-top: 0;
  }
  .course-code {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 12px;
    color: var(--muted);
    padding-top: 2px;
  }
  .course-title {
    font-family: var(--font-serif);
    font-size: 15.5px;
    color: var(--text);
    font-weight: 500;
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }
  .course-badge {
    font-family: var(--font-sans);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    border: 1px solid var(--border);
    padding: 1px 6px;
    border-radius: 2px;
    font-weight: 400;
  }
  .course-desc {
    font-family: var(--font-serif);
    font-size: 14px;
    color: var(--muted);
    margin: 4px 0 0;
    line-height: 1.55;
  }
  .course-meta {
    font-family: var(--font-sans);
    font-size: 11.5px;
    color: var(--muted);
    margin: 6px 0 0;
  }
  .course-meta .dot {
    color: var(--border);
  }
</style>

