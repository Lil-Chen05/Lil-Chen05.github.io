---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import NoteEntry from "../../components/NoteEntry.astro";

const notes = (await getCollection("notes")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---

<Layout
  title="Notes"
  description="Short posts — what I'm learning, thinking, and working on."
>
  <h1 class="text-3xl">Notes</h1>
  <p class="mt-3 text-muted">
    Short posts/updates about things I'm learning, small wins.
    Roughly in reverse chronological order.
  </p>

  <div class="mt-8">
    {notes.map((n) => <NoteEntry note={n} />)}
    {
      notes.length === 0 && (
        <p class="mt-6 text-muted">Nothing yet. Check back later.</p>
      )
    }
  </div>
</Layout>
