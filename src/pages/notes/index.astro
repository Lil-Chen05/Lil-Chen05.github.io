---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import NoteEntry from "../../components/NoteEntry.astro";

const notes = (await getCollection("notes")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---

<Layout
  title="Notes"
  description="Short posts — what I'm learning, thinking, and working on."
>
  <h1 class="page-h1">Notes</h1>
  <p class="page-lede">
    Short posts on what I'm learning, thinking, and working on. In reverse chronological
    order.
  </p>

  <div class="mt-8">
    {notes.map((n) => <NoteEntry note={n} />)}
    {
      notes.length === 0 && (
        <p class="mt-6 text-muted">Nothing yet. Check back later.</p>
      )
    }
  </div>
</Layout>

<style>
  .page-h1 {
    font-family: var(--font-serif);
    font-size: 44px;
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.05;
    margin: 0;
    color: var(--text);
  }
  .page-lede {
    font-family: var(--font-serif);
    font-size: 17px;
    color: var(--muted);
    margin: 12px 0 0;
    max-width: 56ch;
  }
  .mt-8 {
    margin-top: 2rem;
  }
</style>
