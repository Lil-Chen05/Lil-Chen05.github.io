---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---

<Layout
  title="Blog"
  description="Long-form posts."
  noindex
>
  <h1 class="text-3xl">Blog</h1>
  <p class="mt-3 text-muted">
    Long-form posts. Nothing here yet.
  </p>

  <div class="mt-8">
    {
      posts.map((p) => (
        <article class="border-t border-border py-6">
          <h3 class="text-lg">
            <a href={`/blog/${p.id}`} class="text-text no-underline hover:text-accent">
              {p.data.title}
            </a>
          </h3>
          <p class="mt-2 text-muted">{p.data.description}</p>
        </article>
      ))
    }
  </div>
</Layout>

<style>
  article a.no-underline {
    text-decoration: none;
  }
</style>
