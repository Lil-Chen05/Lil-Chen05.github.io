---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import NoteEntry from "../components/NoteEntry.astro";
import ActivityPlant from "../components/ActivityPlant.astro";
import { computeActivity } from "../lib/activity";

const featuredProjects = (await getCollection("projects"))
  .filter((p) => p.data.featured)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const recentNotes = (await getCollection("notes"))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 5);

const { score, lastActivity } = await computeActivity();
---

<Layout wide>
  <section class="flex items-start gap-6 sm:gap-8">
    <img
      src="/images/jerry.jpg"
      alt="Jerry Chen"
      width="84"
      height="84"
      class="hidden shrink-0 rounded-full border border-border object-cover sm:block"
      style="width: 84px; height: 84px;"
    />
    <div class="flex-1">
      <h1 class="text-3xl sm:text-4xl">Jerry Chen</h1>
      <p class="mt-3 text-muted">
        Computer science at McGill. I work across software engineering, AI, and
        language research, and write short notes about what I'm learning.
      </p>
    </div>
  </section>

  <div class="home-split mt-16">
    <div class="home-main">
      <section>
        <div class="flex items-baseline justify-between">
          <h2 class="font-sans text-xs uppercase tracking-widest text-muted">
            Selected projects
          </h2>
          <a href="/projects" class="font-sans text-xs">All projects →</a>
        </div>
        <div class="mt-4">
          {featuredProjects.map((p) => <ProjectCard project={p} />)}
          {
            featuredProjects.length === 0 && (
              <p class="mt-6 text-muted">No featured projects yet.</p>
            )
          }
        </div>
      </section>

      <section class="mt-16">
        <div class="flex items-baseline justify-between">
          <h2 class="font-sans text-xs uppercase tracking-widest text-muted">
            Recent notes
          </h2>
          <a href="/notes" class="font-sans text-xs">All notes →</a>
        </div>
        <div class="mt-4">
          {recentNotes.map((n) => <NoteEntry note={n} />)}
          {
            recentNotes.length === 0 && (
              <p class="mt-6 text-muted">No notes yet.</p>
            )
          }
        </div>
      </section>
    </div>

    <div class="home-aside">
      <ActivityPlant score={score} lastActivity={lastActivity} />
    </div>
  </div>
</Layout>

<style>
  .home-main {
    min-width: 0;
    max-width: 65ch;
  }
  .home-aside {
    display: none;
  }
  @media (min-width: 1024px) {
    .home-split {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 260px;
      gap: 48px;
      align-items: start;
    }
    .home-aside {
      display: block;
      position: sticky;
      top: 5rem;
    }
  }
</style>
