---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const courses = (await getCollection("courses")).sort((a, b) =>
  a.data.code.localeCompare(b.data.code)
);
---

<Layout
  title="Courses"
  description="University course reflections."
>
  <h1 class="text-3xl">Courses</h1>
  <p class="mt-3 text-muted">
    Short reflections on the classes I've taken at McGill.
  </p>

  <div class="mt-8">
    {
      courses.map((c) => (
        <article class="border-t border-border py-6">
          <header class="flex items-baseline justify-between gap-4">
            <h3 class="text-lg">
              <a
                href={`/courses/${c.id}`}
                class="text-text no-underline hover:text-accent"
              >
                <span class="font-sans text-sm text-muted">{c.data.code}</span>
                <span class="mx-2">·</span>
                {c.data.title}
              </a>
            </h3>
            <span class="shrink-0 font-sans text-xs text-muted">
              {c.data.term}
            </span>
          </header>
        </article>
      ))
    }
    {
      courses.length === 0 && (
        <p class="mt-6 text-muted">Nothing yet.</p>
      )
    }
  </div>
</Layout>

<style>
  article a.no-underline {
    text-decoration: none;
  }
</style>
