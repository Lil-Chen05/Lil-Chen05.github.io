    <h2 class="font-sans text-xs uppercase tracking-widest text-muted">
      Hobbies
    </h2>
    <p class="mt-4">Soccer with Inter Montreal. Fashion and sustainability.</p>
  </section>

  <section class="mt-12">
    <h2 class="font-sans text-xs uppercase tracking-widest text-muted">
      Reading
    </h2>
    <p class="mt-4 text-muted">Nothing listed yet.</p>
  </section>

  <section class="mt-12">
    <h2 class="font-sans text-xs uppercase tracking-widest text-muted">
      Currently learning
    </h2>
    <p class="mt-4 text-muted">Nothing listed yet.</p>
  </section>
</Layout>
