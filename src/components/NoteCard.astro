---
import type { CollectionEntry } from "astro:content";

interface Props {
  note: CollectionEntry<"notes">;
}

const { note } = Astro.props;
const { title, date } = note.data;
const formattedDate = date.toLocaleDateString("en-CA", {
  year: "numeric",
  month: "short",
  day: "numeric",
});
---

<a href={`/notes/${note.id}`} class="block no-underline group">
  <article class="border-t border-border py-5">
    <div class="flex items-baseline justify-between gap-4">
      <h3 class="text-lg text-text group-hover:text-accent">{title}</h3>
      <time class="shrink-0 font-sans text-xs text-muted" datetime={date.toISOString()}>
        {formattedDate}
      </time>
    </div>
  </article>
</a>

<style>
  a.no-underline {
    text-decoration: none;
  }
</style>
