---
interface Props {
  tag: string;
  active?: boolean;
}
const { tag, active = false } = Astro.props;
const label = tag.toUpperCase();
---

<span class:list={["tag", { on: active }]}>{label}</span>

<style>
  .tag {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-sans);
    font-size: 10.5px;
    font-weight: 500;
    letter-spacing: 0.12em;
    color: var(--muted);
    padding: 2px 7px;
    border: 1px solid var(--border);
    border-radius: 3px;
    line-height: 1.5;
  }
  .tag.on {
    color: var(--accent);
    border-color: var(--accent);
  }
</style>
