---
import Layout from "../layouts/Layout.astro";

interface Props {
  title: string;
  description?: string;
  date?: Date;
  meta?: string;
  eyebrow?: string;
  backHref?: string;
  backLabel?: string;
}

const {
  title,
  description,
  date,
  meta,
  eyebrow,
  backHref = "/",
  backLabel = "Back",
} = Astro.props;

const formattedDate = date
  ? date.toLocaleDateString("en-CA", {
      year: "numeric",
      month: "long",
      day: "numeric",
    })
  : null;
---

<Layout title={title} description={description}>
  <a href={backHref} class="font-sans text-sm">← {backLabel}</a>

  <header class="mt-6">
    {
      eyebrow && (
        <p class="font-sans text-xs uppercase tracking-widest text-muted">
          {eyebrow}
        </p>
      )
    }
    <h1 class="mt-2 text-3xl sm:text-4xl">{title}</h1>
    {
      (formattedDate || meta) && (
        <p class="mt-3 font-sans text-sm text-muted">
          {formattedDate && <time datetime={date?.toISOString()}>{formattedDate}</time>}
          {formattedDate && meta && <span class="mx-2">·</span>}
          {meta}
        </p>
      )
    }
  </header>

  <article class="prose mt-10">
    <slot />
  </article>
</Layout>

<style>
  .prose :global(h2) {
    font-size: 1.5rem;
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }
  .prose :global(h3) {
    font-size: 1.2rem;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }
  .prose :global(p) {
    margin-top: 1rem;
  }
  .prose :global(ul),
  .prose :global(ol) {
    margin-top: 1rem;
    padding-left: 1.5rem;
  }
  .prose :global(li) {
    margin-top: 0.25rem;
  }
  .prose :global(ul) {
    list-style: disc;
  }
  .prose :global(ol) {
    list-style: decimal;
  }
  .prose :global(code) {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.9em;
    background: var(--surface);
    padding: 0.1em 0.3em;
    border-radius: 3px;
  }
  .prose :global(pre) {
    margin-top: 1rem;
    padding: 1rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    overflow-x: auto;
  }
  .prose :global(pre code) {
    background: transparent;
    padding: 0;
  }
  .prose :global(blockquote) {
    margin-top: 1rem;
    padding-left: 1rem;
    border-left: 2px solid var(--border);
    color: var(--muted);
    font-style: italic;
  }
</style>
