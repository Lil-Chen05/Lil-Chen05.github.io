---
interface Props {
  src: string;
  caption?: string;
}
const { src, caption } = Astro.props;
---

<figure class="gallery-item">
  <div class="gallery-frame">
    <img src={src} alt={caption ?? ""} loading="lazy" />
  </div>
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .gallery-item {
    margin: 0;
    min-width: 0;
  }
  .gallery-frame {
    border: 1px solid var(--border);
    background: var(--surface);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .gallery-frame img {
    max-width: 100%;
    width: auto;
    height: auto;
    display: block;
  }
  figcaption {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 12px;
    color: var(--muted);
    margin-top: 8px;
  }
</style>
