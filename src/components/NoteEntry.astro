---
import type { CollectionEntry } from "astro:content";
import { render } from "astro:content";

interface Props {
  note: CollectionEntry<"notes">;
}

const { note } = Astro.props;
const { title, date } = note.data;
const { Content } = await render(note);
const formattedDate = date.toLocaleDateString("en-CA", {
  year: "numeric",
  month: "short",
  day: "numeric",
});
---

<article class="border-t border-border py-8">
  <header class="flex items-baseline justify-between gap-4">
    <h3 class="text-lg">
      <a href={`/notes/${note.id}`} class="no-underline text-text hover:text-accent">
        {title}
      </a>
    </h3>
    <time
      class="shrink-0 font-sans text-xs text-muted"
      datetime={date.toISOString()}
    >
      {formattedDate}
    </time>
  </header>
  <div class="prose mt-3">
    <Content />
  </div>
</article>

<style>
  article :global(a.no-underline) {
    text-decoration: none;
  }
  .prose :global(p) {
    margin-top: 0.5rem;
  }
  .prose :global(p):first-child {
    margin-top: 0;
  }
</style>
