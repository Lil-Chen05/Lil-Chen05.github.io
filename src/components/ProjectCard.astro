---
import type { CollectionEntry } from "astro:content";
import TagPill from "./TagPill.astro";

interface Props {
  project: CollectionEntry<"projects">;
}

const { project } = Astro.props;
const { title, description, tags } = project.data;
---

<a href={`/projects/${project.id}`} class="block no-underline group">
  <article class="border-t border-border py-6">
    <div class="flex items-baseline justify-between gap-4">
      <h3 class="text-xl text-text group-hover:text-accent">{title}</h3>
      <div class="flex shrink-0 gap-1.5 font-sans">
        {tags.map((t) => <TagPill tag={t} />)}
      </div>
    </div>
    <p class="mt-2 text-muted">{description}</p>
  </article>
</a>

<style>
  a.no-underline {
    text-decoration: none;
  }
</style>
