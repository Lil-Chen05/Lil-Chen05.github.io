---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
  wide?: boolean;
}

const { title, description, noindex, wide } = Astro.props;
const mainClass = wide
  ? "mx-auto w-full max-w-5xl flex-1 px-6 py-12"
  : "mx-auto w-full max-w-prose flex-1 px-6 py-12";
const pageTitle = title ? `${title} · Jerry Chen` : "Jerry Chen";
const pageDesc =
  description ??
  "Jerry Chen — computer science at McGill. Notes and projects across software engineering, AI, and language research.";
const ogImage = new URL("/og-default.svg", Astro.site).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={Astro.url.href} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDesc} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="generator" content={Astro.generator} />

    <script is:inline>
      (() => {
        const stored = localStorage.getItem("theme");
        const prefers = window.matchMedia(
          "(prefers-color-scheme: dark)"
        ).matches;
        document.documentElement.dataset.theme =
          stored ?? (prefers ? "dark" : "light");
      })();
    </script>
  </head>
  <body>
    <Nav />
    <main class={mainClass}>
      <slot />
    </main>
    <Footer />
  </body>
</html>
